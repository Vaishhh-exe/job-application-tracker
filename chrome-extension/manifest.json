{
  "manifest_version": 3,
  "name": "Meridian Job Saver",
  "version": "1.0",
  "description": "Save LinkedIn job listings to your Meridian job application tracker with one click",
  
  "permissions": [
    "storage",
    "activeTab"
  ],
  
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://job-application-tracker-wheat.vercel.app/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save Job to Meridian"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}